---
import { Image } from "astro:assets";
import Layout from "../../../layouts/Layout.astro";
import adem_rond from "../../../assets/rondevormen/adem_rond.png";
import bewustzijn_rond from "../../../assets/rondevormen/bewustzijn_rond.png";
import hart_rond from "../../../assets/rondevormen/hart_rond.png";
import lichaam_rond from "../../../assets/rondevormen/lichaam_rond.png";
import ContactSection from "../../../components/Contact-section.astro";

import {
  getLangFromUrl,
  useTranslations,
  getStaticPaths,
} from "../../../i18n/utils";
export { getStaticPaths };
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t("filosofie.title")}>
  <section
    class="intro-pillars back-red text-align-center text-white regular-font"
  >
    <div class="text-margin">
      <p>{t("intro-pillars.text1")}</p>
      <p class="papyrus-font" set:html={t("intro-pillars.text2")} />
    </div>
  </section>
  <section class="pillars back-gray text-align-center center text-black">
    <div class="container">
      <h2 class="text-red margin-0">{t("pillars.bewustzijn.title")}</h2>
      <div class="col2">
        <div>
          <h3 class="text-red">{t("pillars.bewustzijn.subtitle1")}</h3>
          <div class="img-container bold">
            <Image
              src={bewustzijn_rond}
              alt="Tekening van bewustzijn"
              height={400}
              width={400}
              loading="eager"
            />
            <div class="img-text">
              <div class="left-shape"></div>
              <div class="right-shape"></div>
              <div class="spacer"></div>
              <p>{t("pillars.bewustzijn.img.text1")}</p>
              <p>{t("pillars.bewustzijn.img.text2")}</p>
            </div>
          </div>
        </div>
        <div>
          <h3 class="text-red">{t("pillars.bewustzijn.subtitle2")}</h3>
          <ul class="text-align-justify infinity-list regular-font">
            <li>{t("pillars.bewustzijn.list1")}</li>
            <li>{t("pillars.bewustzijn.list2")}</li>
            <li>{t("pillars.bewustzijn.list3")}</li>
            <li>{t("pillars.bewustzijn.list4")}</li>
          </ul>
        </div>
      </div>
    </div>
    <div class="container">
      <h2 class="text-red margin-0">{t("pillars.adem.title")}</h2>
      <div class="col2">
        <div>
          <h3 class="text-red">{t("pillars.adem.subtitle1")}</h3>
          <div class="img-container bold">
            <Image
              src={adem_rond}
              alt="Tekening van adem"
              height={400}
              width={400}
            />
            <div class="img-text">
              <div class="left-shape"></div>
              <div class="right-shape"></div>
              <div class="spacer"></div>
              <p>{t("pillars.adem.img.text1")}</p>
              <p>{t("pillars.adem.img.text2")}</p>
            </div>
          </div>
        </div>
        <div class="text-container">
          <h3 class="text-red">{t("pillars.adem.subtitle2")}</h3>
          <ul class="text-align-justify infinity-list regular-font">
            <li>{t("pillars.adem.list1")}</li>
            <li>{t("pillars.adem.list2")}</li>
            <li>{t("pillars.adem.list3")}</li>
            <li>{t("pillars.adem.list4")}</li>
          </ul>
        </div>
      </div>
    </div>
    <div class="container">
      <h2 class="text-red margin-0">{t("pillars.hart.title")}</h2>
      <div class="col2">
        <div>
          <h3 class="text-red">{t("pillars.hart.subtitle1")}</h3>
          <div class="img-container bold">
            <Image
              src={hart_rond}
              alt="Tekening van hart"
              height={400}
              width={400}
            />
            <div class="img-text">
              <div class="left-shape"></div>
              <div class="right-shape"></div>
              <div class="spacer"></div>
              <p>{t("pillars.hart.img.text1")}</p>
              <p>{t("pillars.hart.img.text2")}</p>
            </div>
          </div>
        </div>
        <div>
          <h3 class="text-red">{t("pillars.hart.subtitle2")}</h3>
          <ul class="text-align-justify infinity-list regular-font">
            <li>{t("pillars.hart.list1")}</li>
            <li>{t("pillars.hart.list2")}</li>
            <li>{t("pillars.hart.list3")}</li>
          </ul>
        </div>
      </div>
    </div>
    <div class="container">
      <h2 class="text-red margin-0">{t("pillars.bewust.title")}</h2>
      <div class="col2">
        <div>
          <h3 class="text-red">{t("pillars.bewust.subtitle1")}</h3>
          <div class="img-container bold">
            <Image
              src={lichaam_rond}
              alt="Tekening van lichaam"
              height={400}
              width={400}
            />
            <div class="img-text">
              <div class="left-shape"></div>
              <div class="right-shape"></div>
              <div class="spacer"></div>
              <p>{t("pillars.bewust.img.text1")}</p>
              <p>{t("pillars.bewust.img.text2")}</p>
            </div>
          </div>
        </div>
        <div>
          <h3 class="text-red">{t("pillars.bewust.subtitle2")}</h3>
          <ul class="text-align-justify infinity-list regular-font">
            <li>{t("pillars.bewust.list1")}</li>
            <li>{t("pillars.bewust.list2")}</li>
            <li>{t("pillars.bewust.list3")}</li>
            <li>{t("pillars.bewust.list4")}</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
  <section class="essentie back-red text-white">
    <h3
      class="text-align-center text-margin"
      set:html={t("filosofie.essentie.text1")}
    />
    <ul>
      <li set:html={t("filosofie.essentie.li1")} />
      <li set:html={t("filosofie.essentie.li2")} />
      <li set:html={t("filosofie.essentie.li3")} />
    </ul>
    <p class="text-align-center">{t("filosofie.essentie.text2")}</p>
  </section>
  <ContactSection color="gray" />

  <style>
    section {
      padding: 2rem;
    }

    .title {
      font-weight: 600;
      font-size: 1.3rem;
    }

    .col2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      width: 100%;
      max-width: 1200px;
      padding: 5rem;
      padding-top: 0;
    }

    .pillars .container {
      border-bottom: 2px solid #a5655f57;
      margin: 2rem 0;
    }

    .pillars .col2:last-of-type {
      border-bottom: none;
    }

    .img-container {
      display: flex;
      align-items: center;
      justify-content: center;

      position: relative;
      width: 100%;
      height: auto;

      max-width: 300px;
      overflow: hidden;
      cursor: pointer;
      margin: auto;
    }

    .img-container img {
      display: block;
      width: 100%;
      max-width: 300px;
      height: auto;
    }

    .img-text {
      position: absolute;
      text-align: center;
      width: 100%;
      height: 100%;

      padding: 0;
      box-sizing: border-box;
      border-radius: 50%;
      color: white;
      background-color: rgba(0, 0, 0, 0.6);

      opacity: 0;
      transition: opacity 0.6s ease;
      overflow: hidden;
    }

    .img-text p {
      margin: auto;
      padding: 10px;
      font-size: 1rem;
      line-height: 1.4;
    }

    .left-shape {
      width: 50%;
      height: 100%;
      float: left;
      shape-outside: polygon(
        0% 0%,
        100% 0%,
        60% 10%,
        30% 25%,
        15% 50%,
        30% 75%,
        60% 90%,
        100% 100%,
        0% 100%
      );
    }

    .right-shape {
      width: 50%;
      height: 100%;
      float: right;
      /* Approximating a circular curve on the left edge of the float */
      shape-outside: polygon(
        100% 0%,
        0% 0%,
        40% 10%,
        70% 25%,
        85% 50%,
        70% 75%,
        40% 90%,
        0% 100%,
        100% 100%
      );
    }

    .spacer {
      height: 20%;
    }

    .img-container:hover .img-text {
      opacity: 1;
    }

    .essentie ul {
      margin: auto;
      width: fit-content;
      background-color: var(--mooyo-gray);
      color: var(--mooyo-red);
      padding: 2rem 4rem;
      border-radius: 0.5rem;
    }

    /* Responsive */

    @media (max-width: 1205px) {
      .open-hart {
        display: none;
      }
    }

    @media (max-width: 925px) {
      .col2 {
        grid-template-columns: 1fr;
        gap: 2rem;
      }
      .pillars img {
        max-width: 100%;
      }
    }
  </style>
</Layout>
