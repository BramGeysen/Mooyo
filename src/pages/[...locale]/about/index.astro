---
import { Image } from "astro:assets";
import Layout from "../../../layouts/Layout.astro";
import {
  getLangFromUrl,
  useTranslations,
  getStaticPaths,
} from "../../../i18n/utils";
import afrika from "../../../assets/afrika.png";
import vuur_camping from "../../../assets/vuur_camping.jpeg";
import ContactSection from "@components/Contact-section.astro";

export { getStaticPaths };
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t("about.title")}>
  <section class="s1 back-gray text-align-center">
    <h1 class="text-red">{t("about.s1.title")}</h1>
    <p class="text-black">{t("about.s1.text")}</p>
  </section>

  <section class="s2 back-white text-black text-align-justify regular-font">
    <div class="center img-container">
      <Image
        class="img"
        src={afrika}
        alt="Tekening van de zon"
        width={500}
        height={500}
        loading="eager"
      />
    </div>
    <div class="text">
      <h2 class="text-red papyrus-font">{t("about.s2.e1.title")}</h2>
      <p>{t("about.s2.e1.text1")}</p>
      <p>{t("about.s2.e1.text2")}</p>
      <p>{t("about.s2.e1.text3")}</p>
      <p>{t("about.s2.e1.text4")}</p>
      <p>{t("about.s2.e1.text6")}</p>
      <p>{t("about.s2.e1.text7")}</p>
    </div>

    <div class="text right row4">
      <h2 class="text-red papyrus-font">
        {t("about.s2.e2.title")}
      </h2>
      <p>{t("about.s2.e2.text1")}</p>
      <p>{t("about.s2.e2.text2")}</p>
    </div>

    <div class="img-container row3">
      <Image
        class="img"
        src={vuur_camping}
        alt="Foto kamperen met kampvuur"
        width={1000}
        height={1000}
      />
    </div>
  </section>

  <ContactSection color="gray" />
</Layout>

<style>
  .s1,
  .s3 {
    padding: 2rem;
  }

  .s2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .s2 .text {
    padding: 3rem;
    height: auto;
  }

  .img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .img-container {
    width: 100%;
    height: auto;
    min-height: 400px;
    max-height: 700px;
    overflow: hidden;
  }

  .center {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* Responsive Breakdown adjustments */
  @media (max-width: 1100px) {
    .s2 {
      display: flex;
      flex-direction: column; /* Cleaner layout ordering strategy for simple viewports */
    }

    .img-container {
      height: 400px;
    }

    .s2 .text {
      padding: 2rem;
    }
    .img-wrapper-first {
      order: 1;
    }
    .s2 .text:not(.right) {
      order: 2;
    }
    .row3 {
      order: 3;
    }
    .row4 {
      order: 4;
    }
  }

  @media (max-width: 600px) {
    .img-container {
      height: 300px;
    }

    .s1 h1 {
      font-size: 1.8rem;
    }
  }
</style>
