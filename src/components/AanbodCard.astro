---
import { Image } from "astro:assets";
import hart_rond from "@src/assets/zon.jpg";
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "@src/i18n/utils";
import type { ImageMetadata } from "astro";
const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);
const t = useTranslations(lang);

interface Props {
  title: string;
  text: string;
  link: string;
  img: ImageMetadata;
}

const { title, text, link, img } = Astro.props;
---

<a href={translatePath(`/aanbod#${link}`)}>
  <div class="container back-white">
    <div class="img-container">
      <Image class="img" src={img} width={400} height={400} alt="Hart" />
    </div>
    <div class="text-container">
      <h3 class="text-red text-align-center">{title}</h3>
      <p>{text}</p>
      <button class="bold" title="klik voor meer"
        >{t("aanbodCard.seeMore")}</button
      >
    </div>
  </div>
</a>

<style>
  .container {
    display: flex;
    align-items: center;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    border-radius: 1rem;
    height: 100%;
  }

  .img-container {
    width: 100%;
    max-height: 400px;
    overflow: hidden;
    border-bottom: 1px solid var(--mooyo-red);
  }

  .img {
    display: block;
    width: 100%;
    height: auto;
  }

  .text-container {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    flex: 1;
  }
  button {
    margin-top: auto;
    align-self: flex-end;
    padding: 1rem 5rem;
  }
</style>
