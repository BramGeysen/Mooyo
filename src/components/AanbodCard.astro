---
import { Image } from "astro:assets";
import hart_rond from "@src/assets/zon.jpg";
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "@src/i18n/utils";
const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);
const t = useTranslations(lang);

interface Props {
  title: string;
  text: string;
  link: string;
  img: "hart";
}

const { title, text, link, img } = Astro.props;
---

<a href={translatePath(`/aanbod#${link}`)}>
  <div class="container back-white">
    <div class="img-container">
      <Image class="img" src={hart_rond} width={400} height={400} alt="Hart" />
    </div>
    <div class="text-container">
      <h3 class="text-red text-align-center">{title}</h3>
      <p>{text}</p>
      <button class="bold" title="klik voor meer"> lees meer →</button>
    </div>
  </div>
</a>

<style>
  .container {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;

    overflow: hidden;
    border-radius: 1rem;
  }

  .img-container {
    width: 100%;
    max-height: 400px;
    overflow: hidden;
    border-bottom: 1px solid var(--mooyo-red);
  }

  .img {
    width: 100%;
    height: auto;
  }

  .text-container {
    padding: 2rem;
  }

  button {
    float: right;
    padding: 1rem 5rem;
  }
</style>
