---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import DropDownContainer from "./DropDownContainer.astro";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
  color?: string;
}
const { color } = Astro.props;

const sectionClasses: string = color == 'red' ? "back-red text-white" : "back-gray text-black"
---

<section class=`prices ${sectionClasses} regular-font`>
  <h2 class="papyrus-font">{t('Prices.title')}</h2>
  <!-- Section 1: Individuele begeleidingen -->
  <DropDownContainer title={t("Prices.title.individual")} color={color}>
    <div class="flex">
      <!-- Card 1: E1 -->
      <div class="card expanding">
        <div class="main">
          <h4 class="bold text-red papyrus-font">
            {t("Prices.e1.title1")}
          </h4>
          <ul class="infinity-list text-black">
            <li>{t("Prices.e1.li1")}</li>
            <li>{t("Prices.e1.li2")}</li>
          </ul>
          <p class="seeMore">{t("Prices.seeMore")}</p>
          <div class="details">
            <p>{t("Prices.e1.details")}</p>
          </div>
        </div>
      </div>

      <!-- Card 2: Adolescenten -->
      <div class="card expanding">
        <div class="main">
          <h4 class="bold text-red papyrus-font">
            {t("Prices.adolescenten.title")}
          </h4>
          <ul class="infinity-list text-black">
            <li>{t("Prices.adolescenten.li1")}</li>
            <li>{t("Prices.adolescenten.li2")}</li>
          </ul>
          <p class="seeMore">{t("Prices.seeMore")}</p>
          <div class="details">
            <p>{t("Prices.adolescenten.details")}</p>
          </div>
        </div>
      </div>
    </div>
    <div class="flex">
      <!-- Card 3: Hartcoherentie -->
      <div class="card expanding">
        <div class="main">
          <h4 class="bold text-red papyrus-font">{t("Prices.burnout.title")}</h4>
          <ul class="infinity-list text-black">
            <li>{t("Prices.e1.li1")}</li>
            <li>{t("Prices.e1.li2")}</li>
          </ul>
          <p class="seeMore">{t("Prices.seeMore")}</p>
          <div class="details">
            <p>{t("Prices.burnout.description")}</p>
            <ul>
              <li>
                <span class="text-red bold">{t("Prices.burnout.stress.title")}</span>
                {t("Prices.burnout.stress.text")}
              </li>
              <li>
                <span class="text-red bold">{t("Prices.burnout.emotions.title")}</span>
                {t("Prices.burnout.emotions.text")}
              </li>
              <li>
                <span class="text-red bold">{t("Prices.burnout.connection.title")}</span>
                {t("Prices.burnout.connection.text")}
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Card 4: Koppels -->
      <div class="card expanding">
        <div class="main">
          <h4 class="bold text-red papyrus-font">
            {t("Prices.koppels.title")}
          </h4>
          <ul class="infinity-list text-black">
            <li>{t("Prices.koppels.li1")}</li>
            <li>{t("Prices.koppels.li2")}</li>
          </ul>
          <p class="seeMore">{t("Prices.seeMore")}</p>
          <div class="details">
            <p>{t("Prices.koppels.details")}</p>
          </div>
        </div>
      </div>
    </div>
  </DropDownContainer>

  <!-- Section 2: Workshops -->
  <DropDownContainer title={t("Prices.title.workshops")} color={color}>
    <div class="flex">
      <!-- Workshop Card 1: Voorbij je construct -->
      <div class="card expanding text-align-justify">
        <div class="main">
          <h4 class="bold text-red text-align-center papyrus-font">
            {t("Prices.construct.title")}
          </h4>
          <p>{t("Prices.construct.text")}</p>
          <p>
            {t("Prices.info")}
            <a href="mailto:bramgeysen@gmail.com">bramgeysen@gmail.com</a>
          </p>
          <p class="seeMore">{t("Prices.seeMore")}</p>
          <div class="details">
            <div class="card-aanbod">
              <ul>
                <li>
                  <span class="bold">{t("Prices.label.format")}:</span>
                  {t("Prices.construct.format")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.for")}:</span>
                  {t("Prices.construct.for")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.location")}:</span>
                  {t("Prices.construct.location")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.max")}:</span>
                  {t("Prices.construct.max")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.data")}:</span>
                  {t("Prices.construct.data")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.price")}:</span>
                  {t("Prices.construct.price")}
                </li>
              </ul>
              <p>{t("Prices.construct.lunch")}</p>
            </div>
            <p>{t("Prices.construct.body1")}</p>
            <p>{t("Prices.construct.body2")}</p>
            <p>{t("Prices.construct.body3")}</p>
            <ul>
              <li>{t("Prices.construct.li1")}</li>
              <li>{t("Prices.construct.li2")}</li>
              <li>{t("Prices.construct.li3")}</li>
              <li>{t("Prices.construct.li4")}</li>
            </ul>
            <p class="text-gray text-align-start">
              {t("Prices.collab")}
              <a
                href="https://www.reconstructive.be"
                target="_blank"
                rel="noopener noreferrer">www.reconstructive.be</a
              >
            </p>
          </div>
        </div>
      </div>

      <!-- Workshop Card 2: Reconstructive -->
      <div class="card expanding text-align-justify">
        <div class="main">
          <h4 class="bold text-red text-align-center papyrus-font">
            {t("Prices.reconstructive.title")}
          </h4>
          <p set:html={t("Prices.reconstructive.text")} />
          <p>
            {t("Prices.info")}
            <a href="mailto:bramgeysen@gmail.com">bramgeysen@gmail.com</a>
          </p>
          <p class="seeMore">{t("Prices.seeMore")}</p>
          <div class="details">
            <div class="card-aanbod">
              <ul>
                <li>
                  <span class="bold">{t("Prices.label.format")}:</span>
                  {t("Prices.reconstructive.format")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.for")}:</span>
                  {t("Prices.reconstructive.for")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.location")}:</span>
                  {t("Prices.reconstructive.location")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.max")}:</span>
                  {t("Prices.reconstructive.max")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.data")}:</span>
                  {t("Prices.reconstructive.data")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.price")}:</span>
                  {t("Prices.reconstructive.price")}
                </li>
              </ul>
              <p>{t("Prices.reconstructive.lunch")}</p>
            </div>
            <p>{t("Prices.reconstructive.body1")}</p>
            <p>{t("Prices.reconstructive.body2")}</p>
            <p>{t("Prices.reconstructive.body3")}</p>
            <p>{t("Prices.reconstructive.body4")}</p>
            <ul>
              <li>{t("Prices.reconstructive.li1")}</li>
              <li>{t("Prices.reconstructive.li2")}</li>
              <li>{t("Prices.reconstructive.li3")}</li>
              <li>{t("Prices.reconstructive.li4")}</li>
              <li>{t("Prices.reconstructive.li5")}</li>
            </ul>
            <p class="text-gray text-align-start">
              {t("Prices.collab")}
              <a
                href="https://www.reconstructive.be"
                target="_blank"
                rel="noopener noreferrer">www.reconstructive.be</a
              >
            </p>
          </div>
        </div>
      </div>
    </div>

    <div class="flex">
      <!-- Find your gold -->
      <div class="card expanding">
        <div class="main">
          <h4 class="bold text-red papyrus-font">{t("Prices.gold.title")}</h4>
          <p>{t("Prices.gold.text")}</p>
          <p>
            {t("Prices.info")}
            <a href="mailto:bramgeysen@gmail.com">bramgeysen@gmail.com</a>
          </p>
          <p class="seeMore">{t("Prices.seeMore")}</p>
          <div class="details">
            <div class="card-aanbod">
              <ul>
                <li>
                  <span class="bold">{t("Prices.label.format")}:</span>
                  {t("Prices.reconstructive.format")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.for")}:</span>
                  {t("Prices.gold.for")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.location")}:</span>
                  {t("Prices.gold.location")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.max")}:</span>
                  {t("Prices.gold.max")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.data")}:</span>
                  {t("Prices.gold.data")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.price")}:</span>
                  {t("Prices.gold.price")}
                </li>
              </ul>
            </div>
            <p>{t("Prices.gold.body")}</p>
            <p>{t("Prices.gold.results.title")}</p>
            <ul>
              <li>{t("Prices.gold.li1")}</li>
              <li>{t("Prices.gold.li2")}</li>
              <li>{t("Prices.gold.li3")}</li>
              <li>{t("Prices.gold.li4")}</li>
            </ul>
            <p>{t("Prices.gold.footer")}</p>
          </div>
        </div>
      </div>
      <!-- Deep time walk workshop -->
      <div class="card expanding">
        <div class="main">
          <h4 class="bold text-red papyrus-font">{t("Prices.deeptimewalk.title")}</h4>
          <p>{t("Prices.deeptimewalk.description")}</p>
          <p>
            {t("Prices.info")}
            <a href="mailto:bramgeysen@gmail.com">bramgeysen@gmail.com</a>
          </p>
          <p class="seeMore">{t("Prices.seeMore")}</p>
          <div class="details">
            <h5>{t("Prices.deeptimewalk.experience.title")}</h5>
            <p>{t("Prices.deeptimewalk.experience.text")}</p>
            <h5>{t("Prices.deeptimewalk.perspective.title")}</h5>
            <p>{t("Prices.deeptimewalk.perspective.text")}</p>
            <h5>{t("Prices.deeptimewalk.reflection.title")}</h5>
            <p>{t("Prices.deeptimewalk.reflection.title")}</p>
            <ul>
              <li>
                <span class="text-red bold">{t("Prices.deeptimewalk.body.title")}</span>
                - {t("Prices.deeptimewalk.body.text")}
              </li>
              <li>
                <span class="text-red bold">{t("Prices.deeptimewalk.heart.title")}</span>
                - {t("Prices.deeptimewalk.heart.text")}
              </li>
              <li>
                <span class="text-red bold">{t("Prices.deeptimewalk.head.title")}</span>
                - {t("Prices.deeptimewalk.head.text")}
              </li>
            </ul>
            <p>
              {t("Prices.deeptimewalk.groups.footer")}
              <a href="mailto:bramgeysen@gmail.com">bramgeysen@gmail.com</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </DropDownContainer>

  <!-- Section 3: Organisaties en Teams -->
  <DropDownContainer title={t("Prices.title.organizations")} color={color}>
    <div class="flex">
      <!-- Begeleiding -->
      <div class="card expanding">
        <div class="main">
          <h4 class="bold text-red">{t("Prices.e3.title")}</h4>
          <ul class="infinity-list text-black">
            <li>{t("Prices.e3.li1")}</li>
            <li>{t("Prices.e3.li2")}</li>
          </ul>
          <p class="seeMore">{t("Prices.seeMore")}</p>
          <div class="details">
            <p>{t("Prices.e3.details")}</p>
          </div>
        </div>
      </div>
      <!-- Deep time walk -->
      <div class="card expanding">
        <div class="main">
          <h4 class="bold text-red papyrus-font">{t("Prices.deeptimewalk.title")}</h4>
          <ul class="infinity-list">
            <li>{t("Prices.deeptimewalk.price.text")}</li>
          </ul>
          <p>{t("Prices.deeptimewalk.description")}</p>
          <p>
            {t("Prices.info")}
            <a href="mailto:bramgeysen@gmail.com">bramgeysen@gmail.com</a>
          </p>
          <p class="seeMore">{t("Prices.seeMore")}</p>
          <div class="details">
            <h5>{t("Prices.deeptimewalk.experience.title")}</h5>
            <p>{t("Prices.deeptimewalk.experience.text")}</p>
            <h5>{t("Prices.deeptimewalk.perspective.title")}</h5>
            <p>{t("Prices.deeptimewalk.perspective.text")}</p>
            <h5>{t("Prices.deeptimewalk.reflection.title")}</h5>
            <ul class="infinity-list">
              <li>
                <span class="text-red bold">{t("Prices.deeptimewalk.body.title")}</span>
                - {t("Prices.deeptimewalk.body.text")}
              </li>
              <li>
                <span class="text-red bold">{t("Prices.deeptimewalk.heart.title")}</span>
                - {t("Prices.deeptimewalk.heart.text")}
              </li>
              <li>
                <span class="text-red bold">{t("Prices.deeptimewalk.head.title")}</span>
                - {t("Prices.deeptimewalk.head.text")}
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </DropDownContainer>
</section>
<style>
  section {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3vw;
  }

  h5 {
    font-size: 1.2rem;
  }
  .flex {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: flex-start;
    width: 100%;
    perspective: 1000px; /* Gives depth to the animation */
  }

  .card {
    background-color: var(--mooyo-gray);
    padding: 2rem;
    border-radius: 0.5rem;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    margin: 2rem;
    color: black;
    box-sizing: border-box;
  }

  .expanding {
    flex: 1 1 0%;
    overflow: hidden;
    min-width: 0;
    transition: all 0.5s cubic-bezier(0.25, 1, 0.5, 1);
    min-height: 400px;
  }

  .expanding.is-active {
    flex: 2;
  }

  .main {
    margin-left: 2rem;
  }

  .card-aanbod {
    border-bottom: 1px double gray;
  }

  .details {
    opacity: 0;
    max-height: 0;
    transform: translateY(20px);
    transition:
      opacity 1s ease-out,
      transform 0.4s ease-out;
    visibility: hidden;
  }

  .flex-column .details {
    transition: max-height 0.4s ease-in-out;
  }

  .expanding.is-active .details {
    opacity: 1;
    visibility: visible;
    max-height: 2000px;
    width: 100%;
    transform: translateY(0);
    transition: max-height 0.4s ease-in-out;
  }

  .seeMore {
    margin-top: 1rem;
    margin-bottom: 0;
    font-weight: bold;
    transition: opacity 1s ease;
  }

  .expanding.is-active .seeMore {
    opacity: 0;
    height: 0;
    margin: 0;
    overflow: hidden;
  }

  a {
    border-bottom: 1px solid var(--mooyo-red);
    color: var(--mooyo-red);
  }

  @media (max-width: 1200px) {
    .flex {
      flex-direction: column;
    }

    .card {
      width: 80%;
      margin: auto;
      margin-top: 2rem;
      margin-bottom: 2rem;
    }
  }
</style>
<script>
  const cards = document.querySelectorAll('.expanding');

  cards.forEach((card) => {
    card.addEventListener('click', () => {
      cards.forEach((anyCard) => {
        anyCard.classList.remove('is-active');
      });

      card.classList.add('is-active');
    });
  });
</script>