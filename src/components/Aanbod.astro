---
import { getLangFromUrl, useTranslations } from "@src/i18n/utils";
import EAC from "../styles/ExpandingAanbodCard.module.css";
import DropDownContainer from "@components/DropDownContainer.astro";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="prices back-gray">
  <DropDownContainer title="Individuele begeleidingen">
    <div class={EAC.flex}>
      <div class={`${EAC.card} ${EAC.expanding}`}>
        <div class={EAC.main}>
          <h4 class="bold text-red papyrus-font">
            {t("Prices.e1.title1")}
          </h4>
          <ul class="infinity-list text-black">
            <li>{t("Prices.e1.li1")}</li>
            <li>{t("Prices.e1.li2")}</li>
          </ul>
          <p class={EAC.seeMore}>{t("Prices.seeMore")}</p>
        </div>
        <div class={EAC.details}>
          <div class={EAC.detailsInner}>
            <p>{t("Prices.e1.details")}</p>
          </div>
        </div>
      </div>

      <div class={`${EAC.card} ${EAC.expanding}`}>
        <div class={EAC.main}>
          <h4 class="bold text-red papyrus-font">
            {t("Prices.adolescenten.title")}
          </h4>
          <ul class="infinity-list text-black">
            <li>{t("Prices.adolescenten.li1")}</li>
            <li>{t("Prices.adolescenten.li2")}</li>
          </ul>
          <p class={EAC.seeMore}>{t("Prices.seeMore")}</p>
        </div>
        <div class={EAC.details}>
          <div class={EAC.detailsInner}>
            <p>{t("Prices.adolescenten.details")}</p>
          </div>
        </div>
      </div>
    </div>

    <div class={EAC.flex}>
      <div class={`${EAC.card} ${EAC.expanding}`}>
        <div class={EAC.main}>
          <h4 class="bold text-red papyrus-font">Hartcoherentie - burn-out</h4>
          <ul class="infinity-list text-black">
            <li>{t("Prices.e1.li1")}</li>
            <li>{t("Prices.e1.li2")}</li>
          </ul>
          <p class={EAC.seeMore}>{t("Prices.seeMore")}</p>
        </div>
        <div class={EAC.details}>
          <div class={EAC.detailsInner}>
            <p>{t("Prices.e1.details")}</p>
          </div>
        </div>
      </div>

      <div class={`${EAC.card} ${EAC.expanding}`}>
        <div class={EAC.main}>
          <h4 class="bold text-red papyrus-font">
            {t("Prices.koppels.title")}
          </h4>
          <ul class="infinity-list text-black">
            <li>{t("Prices.koppels.li1")}</li>
            <li>{t("Prices.koppels.li2")}</li>
          </ul>
          <p class={EAC.seeMore}>{t("Prices.seeMore")}</p>
        </div>
        <div class={EAC.details}>
          <div class={EAC.detailsInner}>
            <p>{t("Prices.koppels.details")}</p>
          </div>
        </div>
      </div>
    </div>
  </DropDownContainer>

  <DropDownContainer title="Workshops - Transformatie beleving">
    <div class={EAC.flex}>
      <div class={`${EAC.card} ${EAC.expanding} text-align-justify`}>
        <div class={EAC.main}>
          <h4 class="bold text-red text-align-center papyrus-font">
            {t("Prices.patronen.title")}
          </h4>
          <p>{t("Prices.patronen.text")}</p>
          <p>
            {t("Prices.info")}
            <a class={EAC.a} href="mailto:bramgeysen@gmail.com"
              >bramgeysen@gmail.com</a
            >
          </p>
          <p class={EAC.seeMore}>{t("Prices.seeMore")}</p>
        </div>
        <div class={EAC.details}>
          <div class={EAC.detailsInner}>
            <div class={EAC["card-aanbod"]}>
              <ul>
                <li>
                  <span class="bold">{t("Prices.label.format")}:</span>
                  {t("Prices.patronen.format")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.for")}:</span>
                  {t("Prices.patronen.for")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.location")}:</span>
                  {t("Prices.patronen.location")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.max")}:</span>
                  {t("Prices.patronen.max")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.data")}:</span>
                  {t("Prices.patronen.data")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.price")}:</span>
                  {t("Prices.patronen.price")}
                </li>
              </ul>
              <p>{t("Prices.patronen.lunch")}</p>
            </div>
            <p>{t("Prices.patronen.body1")}</p>
            <p>{t("Prices.patronen.body2")}</p>
            <p>{t("Prices.patronen.body3")}</p>
            <ul>
              <li>{t("Prices.patronen.li1")}</li>
              <li>{t("Prices.patronen.li2")}</li>
              <li>{t("Prices.patronen.li3")}</li>
              <li>{t("Prices.patronen.li4")}</li>
            </ul>
            <p class="text-gray text-align-start">
              {t("Prices.collab")}
              <a
                class={EAC.a}
                href="https://www.Cominz.be"
                target="_blank"
                rel="noopener noreferrer">www.Cominz.be</a
              >
            </p>
          </div>
        </div>
      </div>

      <div class={`${EAC.card} ${EAC.expanding} text-align-justify`}>
        <div class={EAC.main}>
          <h4 class="bold text-red text-align-center papyrus-font">
            {t("Prices.reconstructive.title")}
          </h4>
          <p set:html={t("Prices.reconstructive.text")} />
          <p>
            {t("Prices.info")}
            <a class={EAC.a} href="mailto:bramgeysen@gmail.com"
              >bramgeysen@gmail.com</a
            >
          </p>
          <p class={EAC.seeMore}>{t("Prices.seeMore")}</p>
        </div>
        <div class={EAC.details}>
          <div class={EAC.detailsInner}>
            <div class={EAC["card-aanbod"]}>
              <ul>
                <li>
                  <span class="bold">{t("Prices.label.format")}:</span>
                  {t("Prices.reconstructive.format")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.for")}:</span>
                  {t("Prices.reconstructive.for")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.location")}:</span>
                  {t("Prices.reconstructive.location")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.max")}: </span>{
                    t("Prices.reconstructive.max")
                  }
                </li>
                <li>
                  <span class="bold">{t("Prices.label.data")}:</span>
                  {t("Prices.reconstructive.data")}
                </li>
                <li>
                  <span class="bold">{t("Prices.label.price")}:</span>
                  {t("Prices.reconstructive.price")}
                </li>
              </ul>
              <p>{t("Prices.reconstructive.lunch")}</p>
            </div>
            <p>{t("Prices.reconstructive.body1")}</p>
            <p>{t("Prices.reconstructive.body2")}</p>
            <p>{t("Prices.reconstructive.body3")}</p>
            <p>{t("Prices.reconstructive.body4")}</p>
            <ul>
              <li>{t("Prices.reconstructive.li1")}</li>
              <li>{t("Prices.reconstructive.li2")}</li>
              <li>{t("Prices.reconstructive.li3")}</li>
              <li>{t("Prices.reconstructive.li4")}</li>
              <li>{t("Prices.reconstructive.li5")}</li>
            </ul>
            <p class="text-gray text-align-start">
              {t("Prices.collab")}
              <a
                class={EAC.a}
                href="https://www.Cominz.be"
                target="_blank"
                rel="noopener noreferrer">www.Cominz.be</a
              >
            </p>
          </div>
        </div>
      </div>
    </div>
  </DropDownContainer>

  <DropDownContainer title="Organisaties en Teams">
    <div class={EAC.flex}>
      <div class={`${EAC.card} ${EAC.expanding}`}>
        <div class={EAC.main}>
          <h4 class="bold text-red papyrus-font">
            {t("Prices.e1.title1")}
          </h4>
          <ul class="infinity-list text-black">
            <li>{t("Prices.e1.li1")}</li>
            <li>{t("Prices.e1.li2")}</li>
          </ul>
          <p class={EAC.seeMore}>{t("Prices.seeMore")}</p>
        </div>
        <div class={EAC.details}>
          <div class={EAC.detailsInner}>
            <p>{t("Prices.e1.details")}</p>
          </div>
        </div>
      </div>

      <div class={`${EAC.card} ${EAC.expanding}`}>
        <div class={EAC.main}>
          <h4 class="bold text-red papyrus-font">
            {t("Prices.adolescenten.title")}
          </h4>
          <ul class="infinity-list text-black">
            <li>{t("Prices.adolescenten.li1")}</li>
            <li>{t("Prices.adolescenten.li2")}</li>
          </ul>
          <p class={EAC.seeMore}>{t("Prices.seeMore")}</p>
        </div>
        <div class={EAC.details}>
          <div class={EAC.detailsInner}>
            <p>{t("Prices.adolescenten.details")}</p>
          </div>
        </div>
      </div>
    </div>
  </DropDownContainer>
</section>
