---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import DropDownContainer from "./DropDownContainer.astro";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
  color?: string;
}
const { color } = Astro.props;

const sectionClasses: string = color == 'red' ? "back-red" : "back-gray"
---

<section class=`prices ${sectionClasses}`>
  <!-- Section 1: Individuele begeleidingen -->
  <DropDownContainer title="Individuele begeleidingen" color={color}>
    <div class="flex">
      <!-- Card 1: E1 -->
      <div class="card expanding">
        <div class="main">
          <h4 class="bold text-red papyrus-font">
            {t("Prices.e1.title1")}
          </h4>
          <ul class="infinity-list text-black">
            <li>{t("Prices.e1.li1")}</li>
            <li>{t("Prices.e1.li2")}</li>
          </ul>
          <p class="seeMore">{t("Prices.seeMore")}</p>
          <div class="details">
            <div class="detailsInner">
              <p>{t("Prices.e1.details")}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Card 2: Adolescenten -->
      <div class="card expanding">
        <div class="main">
          <h4 class="bold text-red papyrus-font">
            {t("Prices.adolescenten.title")}
          </h4>
          <ul class="infinity-list text-black">
            <li>{t("Prices.adolescenten.li1")}</li>
            <li>{t("Prices.adolescenten.li2")}</li>
          </ul>
          <p class="seeMore">{t("Prices.seeMore")}</p>
          <div class="details">
            <div class="detailsInner">
              <p>{t("Prices.adolescenten.details")}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="flex">
      <!-- Card 3: Hartcoherentie -->
      <div class="card expanding">
        <div class="main">
          <h4 class="bold text-red papyrus-font">Hartcoherentie - burn-out</h4>
          <ul class="infinity-list text-black">
            <li>{t("Prices.e1.li1")}</li>
            <li>{t("Prices.e1.li2")}</li>
          </ul>
          <p class="seeMore">{t("Prices.seeMore")}</p>
          <div class="details">
            <div class="detailsInner">
              <p>{t("Prices.e1.details")}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Card 4: Koppels -->
      <div class="card expanding">
        <div class="main">
          <h4 class="bold text-red papyrus-font">
            {t("Prices.koppels.title")}
          </h4>
          <ul class="infinity-list text-black">
            <li>{t("Prices.koppels.li1")}</li>
            <li>{t("Prices.koppels.li2")}</li>
          </ul>
          <p class="seeMore">{t("Prices.seeMore")}</p>
          <div class="details">
            <div class="detailsInner">
              <p>{t("Prices.koppels.details")}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </DropDownContainer>

  <!-- Section 2: Workshops -->
  <DropDownContainer title="Workshops - Transformatie beleving" color={color}>
    <div class="flex">
      <!-- Workshop Card 1: Patronen -->
      <div class="card expanding text-align-justify">
        <div class="main">
          <h4 class="bold text-red text-align-center papyrus-font">
            {t("Prices.patronen.title")}
          </h4>
          <p>{t("Prices.patronen.text")}</p>
          <p>
            {t("Prices.info")}
            <a href="mailto:bramgeysen@gmail.com">bramgeysen@gmail.com</a>
          </p>
          <p class="seeMore">{t("Prices.seeMore")}</p>
          <div class="details">
            <div class="detailsInner">
              <div class="card-aanbod">
                <ul>
                  <li>
                    <span class="bold">{t("Prices.label.format")}:</span>
                    {t("Prices.patronen.format")}
                  </li>
                  <li>
                    <span class="bold">{t("Prices.label.for")}:</span>
                    {t("Prices.patronen.for")}
                  </li>
                  <li>
                    <span class="bold">{t("Prices.label.location")}:</span>
                    {t("Prices.patronen.location")}
                  </li>
                  <li>
                    <span class="bold">{t("Prices.label.max")}:</span>
                    {t("Prices.patronen.max")}
                  </li>
                  <li>
                    <span class="bold">{t("Prices.label.data")}:</span>
                    {t("Prices.patronen.data")}
                  </li>
                  <li>
                    <span class="bold">{t("Prices.label.price")}:</span>
                    {t("Prices.patronen.price")}
                  </li>
                </ul>
                <p>{t("Prices.patronen.lunch")}</p>
              </div>
              <p>{t("Prices.patronen.body1")}</p>
              <p>{t("Prices.patronen.body2")}</p>
              <p>{t("Prices.patronen.body3")}</p>
              <ul>
                <li>{t("Prices.patronen.li1")}</li>
                <li>{t("Prices.patronen.li2")}</li>
                <li>{t("Prices.patronen.li3")}</li>
                <li>{t("Prices.patronen.li4")}</li>
              </ul>
              <p class="text-gray text-align-start">
                {t("Prices.collab")}
                <a
                  href="https://www.reconstructive.be"
                  target="_blank"
                  rel="noopener noreferrer">www.reconstructive.be</a
                >
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Workshop Card 2: Reconstructive -->
      <div class="card expanding text-align-justify">
        <div class="main">
          <h4 class="bold text-red text-align-center papyrus-font">
            {t("Prices.reconstructive.title")}
          </h4>
          <p set:html={t("Prices.reconstructive.text")} />
          <p>
            {t("Prices.info")}
            <a href="mailto:bramgeysen@gmail.com">bramgeysen@gmail.com</a>
          </p>
          <p class="seeMore">{t("Prices.seeMore")}</p>
          <div class="details">
            <div class="detailsInner">
              <div class="card-aanbod">
                <ul>
                  <li>
                    <span class="bold">{t("Prices.label.format")}:</span>
                    {t("Prices.reconstructive.format")}
                  </li>
                  <li>
                    <span class="bold">{t("Prices.label.for")}:</span>
                    {t("Prices.reconstructive.for")}
                  </li>
                  <li>
                    <span class="bold">{t("Prices.label.location")}:</span>
                    {t("Prices.reconstructive.location")}
                  </li>
                  <li>
                    <span class="bold">{t("Prices.label.max")}:</span>
                    {t("Prices.reconstructive.max")}
                  </li>
                  <li>
                    <span class="bold">{t("Prices.label.data")}:</span>
                    {t("Prices.reconstructive.data")}
                  </li>
                  <li>
                    <span class="bold">{t("Prices.label.price")}:</span>
                    {t("Prices.reconstructive.price")}
                  </li>
                </ul>
                <p>{t("Prices.reconstructive.lunch")}</p>
              </div>
              <p>{t("Prices.reconstructive.body1")}</p>
              <p>{t("Prices.reconstructive.body2")}</p>
              <p>{t("Prices.reconstructive.body3")}</p>
              <p>{t("Prices.reconstructive.body4")}</p>
              <ul>
                <li>{t("Prices.reconstructive.li1")}</li>
                <li>{t("Prices.reconstructive.li2")}</li>
                <li>{t("Prices.reconstructive.li3")}</li>
                <li>{t("Prices.reconstructive.li4")}</li>
                <li>{t("Prices.reconstructive.li5")}</li>
              </ul>
              <p class="text-gray text-align-start">
                {t("Prices.collab")}
                <a
                  href="https://www.reconstructive.be"
                  target="_blank"
                  rel="noopener noreferrer">www.reconstructive.be</a
                >
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </DropDownContainer>

  <!-- Section 3: Organisaties en Teams -->
  <DropDownContainer title="Organisaties en Teams" color={color}>
    <div class="flex">
      <div class="card expanding">
        <div class="main">
          <h4 class="bold text-red papyrus-font">
            {t("Prices.e1.title1")}
          </h4>
          <ul class="infinity-list text-black">
            <li>{t("Prices.e1.li1")}</li>
            <li>{t("Prices.e1.li2")}</li>
          </ul>
          <p class="seeMore">{t("Prices.seeMore")}</p>
          <div class="details">
            <div class="detailsInner">
              <p>{t("Prices.e1.details")}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </DropDownContainer>
</section>
<style>
  section {
    padding: 3vw;
  }

  .flex {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: flex-start;
    width: 100%;
    perspective: 1000px; /* Gives depth to the animation */
  }

  .card {
    background-color: var(--mooyo-gray);
    padding: 2rem;
    border-radius: 0.5rem;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    margin: 2rem;
    color: black;
    box-sizing: border-box;
  }

  .expanding {
    flex: 1 1 0%;
    overflow: hidden;
    min-width: 0;
    transition: all 0.5s cubic-bezier(0.25, 1, 0.5, 1);
    min-height: 400px;
  }

  .expanding.is-active {
    flex: 2;
  }

  .main {
    margin-left: 2rem;
  }

  .card-aanbod {
    border-bottom: 1px double gray;
  }

  .details {
    opacity: 0;
    max-height: 0;
    transform: translateY(20px);
    transition:
      opacity 1s ease-out,
      transform 0.4s ease-out;
    visibility: hidden;
  }

  .flex-column .details {
    transition: max-height 0.4s ease-in-out;
  }

  .expanding.is-active .details {
    opacity: 1;
    visibility: visible;
    max-height: 2000px;
    width: 100%;
    transform: translateY(0);
    transition: max-height 0.4s ease-in-out;
  }

  .seeMore {
    margin-top: 1rem;
    margin-bottom: 0;
    font-weight: bold;
    transition: opacity 1s ease;
  }

  .expanding.is-active .seeMore {
    opacity: 0;
    height: 0;
    margin: 0;
    overflow: hidden;
  }

  a {
    border-bottom: 1px solid var(--mooyo-red);
    color: var(--mooyo-red);
  }

  @media (max-width: 1200px) {
    .flex {
      flex-direction: column;
    }

    .card {
      width: 80%;
      margin: auto;
      margin-top: 2rem;
      margin-bottom: 2rem;
    }
  }
</style>
<script>
  const cards = document.querySelectorAll('.expanding');

  cards.forEach((card) => {
    card.addEventListener('mouseenter', () => {
      cards.forEach((anyCard) => {
        anyCard.classList.remove('is-active');
      });

      card.classList.add('is-active');
    });
  });
</script>